enable-index-owner=1
enable-http-clone=1
enable-index-links=1
enable-commit-graph=1
enable-log-linecount=1
enable-blame=1

# General
root-title=Leonardo's projects
root-desc=Tracking the repositories of leoflo.
clone-url=https://code.leoflo.me/$CGIT_REPO_URL
snapshots=tar.gz zip
scan-path=/srv/git
virtual-root=/

# Dependencies
js=/assets/cgit.js
css=/assets/cgit.css
favicon=/assets/favicon.ico
logo=/assets/cgit.png

# Filters
about-filter=/srv/cgit/filters/about-formatting.sh
commit-filter=/srv/cgit/filters/commit-links.sh
source-filter=/srv/cgit/filters/syntax-highlighting.py
email-filter=/srv/cgit/filters/email-gravatar.py

